# Persistence: "api" (default, SQLite backend) or "demo" (localStorage only)
VITE_PERSISTENCE_MODE=api
# Optional override when API is on another host
# VITE_API_BASE_URL=/api

# Legacy Supabase adapter (optional)
VITE_DB_ADAPTER=supabase
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_KEY=your-supabase-key

# Server (local dev / Fly.io)
# DATABASE_PATH=./data/jobsearch.sqlite
# PORT=3001